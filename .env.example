# Credenciais do aplicativo cadastrado no iFood Developer (Sandbox ou Produção).
# Nunca commitar o .env de verdade — só este .env.example, com valores fake.
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=

# Loja (merchant) padrão usada quando a tela não escolher outra pelo seletor de lojas.
# Descubra o id rodando: python scripts/descobrir_lojas.py
IFOOD_MERCHANT_ID=

# Origem permitida a chamar a API local (server/app.py) via CORS.
# Padrão já é http://localhost:5173 (servidor de dev do Vite); só mude se o front rodar em outra porta/domínio.
VIEWER_ORIGIN=http://localhost:5173

# "1" liga o modo debug do Flask (stack trace no navegador). Deixe "0" (ou vazio) fora do seu ambiente local.
FLASK_DEBUG=0

# Supabase — guarda a auditoria (o antigo data/auditoria.csv virou a tabela "auditoria" no
# Supabase). Rode sql/001_criar_tabela_auditoria.sql uma vez no SQL Editor do projeto antes de
# usar. Use a chave "service_role" (Project Settings > API), NUNCA a "anon"/"publishable" aqui
# — essa chave só deve existir no backend, nunca no front nem em código que vai pro navegador.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
